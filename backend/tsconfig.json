{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "./dist",

    "strict": false,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true
  },

  "include": [
    "**/*.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}